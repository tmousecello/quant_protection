# quant_protection — version-control only code + small text results.
# Large/regenerable artifacts stay out of git (rebuild on the workstation; see WORKSTATION.md).
# NOTE: gitignore does not support trailing/inline comments — keep every pattern on its own line.

# --- Python / venv / OS ---
.venv/
__pycache__/
*.pyc
.DS_Store

# --- logs ---
*.log

# --- dataset (550M; fetch with fetch_sift.sh from the public SIFT1M mirror) ---
sift/

# --- smoke-run outputs (disposable) ---
artifacts_smoke/

# --- heavy / regenerable artifacts (rebuilt by phase0_build.py / phase1_*.py) ---
# 2.2G of .faissindex
artifacts/indexes/
# binary npy ground truth
artifacts/gt/
# per-flip jsonl shards (can grow large on a full run)
artifacts/phase1/raw/
# png figures
artifacts/phase1/charts/

# --- phase2 heavy / binary outputs (rebuilt on the workstation) ---
# per-flip jsonl shards + the dumped index buffers / query-gt .npy the isolated workers mmap
artifacts/phase2/raw/
artifacts/phase2/_substrate/
artifacts/phase2/**/*.npy
artifacts/phase2/**/*.jsonl
artifacts/phase2/**/*.done

# Everything else under artifacts/ IS tracked on purpose (small text results):
#   artifacts/phase2/*.md (README/prompt), vuln_map_pq.csv, graph_edges_characterization.csv,
#   rollup/curve*.csv + region_terms.csv, detection/{coverage.csv,*_summary.json,expected_ranges.json},
#   burst/*_burst.csv
#   artifacts/baseline.{json,csv}
#   artifacts/regions/*.regions.json
#   artifacts/region_accounting.{json,csv,md}
#   artifacts/phase1/regions_aug/*.regions.json
#   artifacts/phase1/vuln_map.{json,csv}
#   artifacts/phase1/sensitivity_table.{csv,md}
#   artifacts/phase1/failure_modes.csv
